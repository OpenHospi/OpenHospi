{
  "name": "openhospi",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "pnpm --filter @openhospi/web dev",
    "dev:mobile": "pnpm --filter @openhospi/mobile start",
    "dev:mobile:prebuild": "pnpm --filter @openhospi/mobile prebuild",
    "dev:mobile:android": "pnpm --filter @openhospi/mobile android",
    "dev:mobile:ios": "pnpm --filter @openhospi/mobile ios",
    "dev:mobile:web": "pnpm --filter @openhospi/mobile web",
    "build": "pnpm --filter @openhospi/web build",
    "dev:docs": "pnpm --filter @openhospi/docs dev",
    "build:docs": "pnpm --filter @openhospi/docs build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint --fix",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "format:write": "pnpm -r format:check --write",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:db": "vitest run apps/web/src/lib/db/__tests__/e2e.test.ts",
    "db:push": "pnpm --filter @openhospi/web db:push",
    "db:push:local": "pnpm --filter @openhospi/web db:push:local",
    "db:generate": "pnpm --filter @openhospi/web db:generate",
    "db:migrate": "pnpm --filter @openhospi/web db:migrate",
    "db:studio": "pnpm --filter @openhospi/web db:studio",
    "db:studio:local": "pnpm --filter @openhospi/web db:studio:local",
    "db:setup:storage:local": "pnpm --filter @openhospi/web db:setup:storage:local",
    "db:seed:local": "pnpm --filter @openhospi/web db:seed:local",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset && pnpm db:push:local && pnpm db:setup:storage:local && pnpm db:seed:local",
    "i18n:check": "i18n-check --source nl --locales packages/i18n/messages",
    "expo:doctor": "cd apps/mobile && npx expo-doctor@latest",
    "expo:install": "pnpm --filter @openhospi/mobile exec expo install",
    "expo:install:check": "pnpm --filter @openhospi/mobile exec expo install --check",
    "expo:install:fix": "pnpm --filter @openhospi/mobile exec expo install --fix",
    "email:dev": "pnpm --filter @openhospi/email dev",
    "clean": "rm -rf **/node_modules **/.next **/.turbo **/dist **/.expo"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@sentry/cli",
      "@swc/core",
      "esbuild",
      "msw",
      "sharp",
      "lightningcss",
      "unrs-resolver"
    ],
    "overrides": {
      "react": "catalog:",
      "react-dom": "catalog:",
      "@types/react": "catalog:",
      "@types/react-dom": "catalog:",
      "drizzle-orm": "catalog:",
      "rollup": ">=4.59.0",
      "hono": ">=4.12.7",
      "@hono/node-server": ">=1.19.10",
      "minimatch@3": "3.1.4",
      "minimatch@9": "9.0.7",
      "minimatch@10": "10.2.3",
      "ajv@6": "6.14.0",
      "esbuild": "0.25.10",
      "lodash": ">=4.17.23",
      "express-rate-limit": ">=8.2.2",
      "lightningcss": "1.30.1",
      "@react-email/body": "^0.3.0",
      "serialize-javascript": ">=7.0.3",
      "undici": ">=7.24.0",
      "next": ">=16.1.7"
    },
    "ignoredBuiltDependencies": [
      "@prisma/engines",
      "prisma"
    ],
    "peerDependencyRules": {
      "ignoreMissing": [
        "prisma",
        "@prisma/client"
      ],
      "allowedVersions": {
        "magicast": ">=0.3.5"
      }
    },
    "configDependencies": {
      "@pnpm/plugin-types-fixer": "0.1.0+sha512-bLww63gRHi7siYTqFJb5qNdcXadU0jv20Et6z5AryMZ7FlLolbEJOrXLpg8+amQZNHHNW1dfFUBGVw/9ezQbFg=="
    }
  },
  "devDependencies": {
    "@lingual/i18n-check": "0.9.2",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "typescript": "catalog:",
    "vitest": "^4.1.0"
  }
}
