{
  "name": "openhospi",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @openhospi/web dev",
    "dev:mobile": "pnpm --filter @openhospi/mobile start",
    "dev:mobile:android": "pnpm --filter @openhospi/mobile android",
    "dev:mobile:ios": "pnpm --filter @openhospi/mobile ios",
    "dev:mobile:web": "pnpm --filter @openhospi/mobile web",
    "build": "pnpm --filter @openhospi/web build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint --fix",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:db": "vitest run packages/database/src/e2e.test.ts",
    "db:push": "pnpm --filter @openhospi/database db:push",
    "db:push:local": "pnpm --filter @openhospi/database db:push:local",
    "db:setup:storage:local": "pnpm --filter @openhospi/database db:setup:storage:local",
    "db:studio": "pnpm --filter @openhospi/database db:studio",
    "db:studio:local": "pnpm --filter @openhospi/database db:studio:local",
    "db:seed:local": "pnpm --filter @openhospi/database db:seed:local",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset && pnpm db:push:local && pnpm db:setup:storage:local && pnpm db:seed:local",
    "i18n:check": "i18n-check --source nl --locales packages/i18n/messages",
    "expo:doctor": "cd apps/mobile && npx expo-doctor@latest",
    "expo:install": "pnpm --filter @openhospi/mobile exec expo install",
    "clean": "rm -rf **/node_modules **/.next **/.turbo **/dist **/.expo"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/engines",
      "@swc/core",
      "esbuild",
      "msw",
      "prisma",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "drizzle-orm": "1.0.0-beta.15-859cf75"
    }
  },
  "devDependencies": {
    "@lingual/i18n-check": "^0.8.19",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
