{
  "name": "@openhospi/email",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "exports": {
    ".": "./src/index.ts",
    "./send": "./src/send.ts"
  },
  "scripts": {
    "dev": "email dev -p 3080",
    "build": "email build",
    "start": "email start",
    "export": "email export --outDir dist-html --pretty",
    "smoke": "tsx scripts/smoke.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"{src,emails,scripts}/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"{src,emails,scripts}/**/*.{ts,tsx,json}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openhospi/i18n": "workspace:*",
    "@openhospi/shared": "workspace:*",
    "next-intl": "^4.9.1",
    "nodemailer": "^8.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-email": "^6.0.0"
  },
  "devDependencies": {
    "@openhospi/eslint-config": "workspace:*",
    "@react-email/ui": "6.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
