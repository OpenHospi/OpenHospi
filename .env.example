# =============================================================================
# OpenHospi — Environment Variables (Web App)
# =============================================================================
# Copy this file to apps/web/.env.local and fill in the values.
#
# For LOCAL development with Docker, run `pnpm supabase:start` and use the
# values from `pnpm supabase:status`. Defaults are shown below.
# =============================================================================

# --- Supabase PostgreSQL ---
# Production only — used by `pnpm db:push` to push schema to remote Supabase
# Not needed for local dev (drizzle.local.config.ts has hardcoded local URL)
# DATABASE_URL=postgresql://[user]:[password]@[host]:[port]/[database]

# Runtime DB connection (used by the app via postgres.js)
# Local:  postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Remote: set via Vercel/hosting env vars
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Supabase Client (for Realtime) ---
# Local:  http://127.0.0.1:54321
# Remote: https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Local: run `pnpm supabase:status` to get the publishable key
# Remote: from Supabase dashboard — API Settings
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<from supabase status or Supabase dashboard>

# --- Supabase Secret Key (for server-side operations: storage, realtime broadcast) ---
# Local: from `pnpm supabase:status` (Secret key, sb_secret_... format)
# Remote: from Supabase dashboard — API Keys
SUPABASE_SECRET_KEY=<from supabase status or Supabase dashboard>

# --- Web Push (VAPID) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<generate with: npx web-push generate-vapid-keys>
VAPID_PRIVATE_KEY=<from the same command above>

# --- Cron Secret (for Supabase Edge Function cron) ---
CRON_SECRET=<generate with: openssl rand -base64 32>

# --- Upstash Redis (rate limiting) ---
KV_REST_API_URL=<from Upstash dashboard>
KV_REST_API_TOKEN=<from Upstash dashboard>

# --- Better Auth ---
# MUST be the same secret across web + admin (shared session DB)
BETTER_AUTH_SECRET=<generate with: openssl rand -base64 32>
BETTER_AUTH_URL=http://localhost:3000

# --- Subdomain routing (leave unset for local dev) ---
# NEXT_PUBLIC_ROOT_DOMAIN=openhospi.nl
# NEXT_PUBLIC_MARKETING_URL=https://openhospi.nl
# NEXT_PUBLIC_APP_URL=https://app.openhospi.nl

# --- InAcademia OIDC ---
# Register at https://inacademia.org — fill in after registration
INACADEMIA_CLIENT_ID=<from InAcademia registration>
INACADEMIA_CLIENT_SECRET=<from InAcademia registration>

# --- GitHub OAuth (dev login + admin bootstrap) ---
GITHUB_CLIENT_ID=<from GitHub Developer Portal>
GITHUB_CLIENT_SECRET=<from GitHub Developer Portal>
# Temporarily set to "false" to allow first admin signup, then remove:
# GITHUB_DISABLE_SIGNUP=false

# --- Email Transport ---
# Google Workspace SMTP Relay (production):
# Auth account: voorzitter@openhospi.nl, sends from noreply@openhospi.nl (group)
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Generic SMTP (local dev — Supabase Inbucket at localhost:2500):
# SMTP_HOST=localhost

# --- Disable Next.js telemetry ---
NEXT_TELEMETRY_DISABLED=1
