# =============================================================================
# OpenHospi — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# =============================================================================

# --- Supabase PostgreSQL ---
DATABASE_URL=postgresql://[user]:[password]@[host]:[port]/[database]

# --- Supabase Client (for Realtime) ---
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<from Supabase dashboard — API Settings>

# --- Vercel Blob (file storage) ---
BLOB_READ_WRITE_TOKEN=<from Vercel dashboard>

# --- Upstash Redis (caching) ---
UPSTASH_REDIS_REST_URL=<from Upstash dashboard>
UPSTASH_REDIS_REST_TOKEN=<from Upstash dashboard>

# --- Better Auth ---
BETTER_AUTH_SECRET=<generate with: openssl rand -base64 32>
BETTER_AUTH_URL=http://localhost:3000

# --- Subdomain routing (leave unset for local dev) ---
# NEXT_PUBLIC_ROOT_DOMAIN=openhospi.nl
# NEXT_PUBLIC_MARKETING_URL=https://openhospi.nl
# NEXT_PUBLIC_APP_URL=https://app.openhospi.nl
# NEXT_PUBLIC_ADMIN_URL=https://admin.openhospi.nl

# --- SURFconext OIDC ---
# Register at https://sp.surfconext.nl — fill in after registration
SURFCONEXT_CLIENT_ID=<from SURFconext SP dashboard>
SURFCONEXT_CLIENT_SECRET=<from SURFconext SP dashboard>

# --- GitHub OAuth ADMIN login ---
GITHUB_CLIENT_ID=<from GitHub Developer Portal>
GITHUB_CLIENT_SECRET=<from GitHub Developer Portal>
# Temporarily set to "false" to allow first admin signup, then remove:
# GITHUB_DISABLE_SIGNUP=false

# --- Disable Next.js telemetry ---
NEXT_TELEMETRY_DISABLED=1