{
  "name": "@openhospi/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./types": "./src/types.ts",
    "./validators": "./src/validators/index.ts"
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:push:local": "drizzle-kit push --config=drizzle.local.config.ts",
    "db:setup:storage:local": "tsx scripts/setup-storage-policies.ts",
    "db:studio": "drizzle-kit studio",
    "db:studio:local": "drizzle-kit studio --config=drizzle.local.config.ts",
    "db:seed:local": "tsx scripts/seed-local.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openhospi/i18n": "workspace:*",
    "@openhospi/shared": "workspace:*",
    "drizzle-orm": "catalog:",
    "postgres": "^3.4.8",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@openhospi/eslint-config": "workspace:*",
    "@supabase/supabase-js": "catalog:",
    "@types/node": "catalog:",
    "dotenv": "^17.3.1",
    "drizzle-kit": "catalog:",
    "drizzle-seed": "1.0.0-beta.15-859cf75",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
