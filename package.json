{
  "name": "openhospi",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "audit": "pnpm audit",
    "setup": "bash scripts/setup.sh",
    "dev:web": "pnpm --filter @openhospi/web dev",
    "dev:mobile": "pnpm --filter @openhospi/mobile start",
    "dev:mobile:prebuild": "pnpm --filter @openhospi/mobile prebuild",
    "dev:mobile:android": "pnpm --filter @openhospi/mobile android",
    "dev:mobile:ios": "pnpm --filter @openhospi/mobile ios",
    "build:web": "pnpm --filter @openhospi/web build",
    "dev:admin": "pnpm --filter @openhospi/admin dev",
    "build:admin": "pnpm --filter @openhospi/admin build",
    "dev:docs": "pnpm --filter @openhospi/docs dev",
    "build:docs": "pnpm --filter @openhospi/docs build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint --fix",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "format:write": "pnpm -r format:check --write",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:db": "vitest run apps/web/src/lib/db/__tests__/e2e.test.ts",
    "db:push": "pnpm --filter @openhospi/database db:push",
    "db:push:local": "pnpm --filter @openhospi/database db:push:local",
    "db:generate": "pnpm --filter @openhospi/database db:generate",
    "db:migrate": "pnpm --filter @openhospi/database db:migrate",
    "db:studio": "pnpm --filter @openhospi/database db:studio",
    "db:studio:local": "pnpm --filter @openhospi/database db:studio:local",
    "db:mobile:generate": "pnpm --filter @openhospi/mobile db:generate",
    "db:setup:storage:local": "pnpm --filter @openhospi/web db:setup:storage:local",
    "db:seed:local": "pnpm --filter @openhospi/web db:seed:local",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset && pnpm db:push:local && pnpm db:setup:storage:local && pnpm db:seed:local",
    "i18n:check": "i18n-check --source nl --locales packages/i18n/messages",
    "expo:doctor": "cd apps/mobile && npx expo-doctor@latest",
    "expo:install": "pnpm --filter @openhospi/mobile exec expo install",
    "expo:install:check": "pnpm --filter @openhospi/mobile exec expo install --check",
    "expo:install:fix": "pnpm --filter @openhospi/mobile exec expo install --fix",
    "dev:email": "pnpm --filter @openhospi/email dev",
    "catalog:check": "pnpm dlx pnpm-catalog-updates check",
    "catalog:update": "pnpm dlx pnpm-catalog-updates update --no-ai --no-install",
    "clean": "rm -rf **/node_modules **/.next **/.turbo **/dist **/.expo"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@sentry/cli",
      "@swc/core",
      "@tensorflow/tfjs-node",
      "esbuild",
      "msw",
      "lightningcss",
      "unrs-resolver"
    ],
    "overrides": {
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "drizzle-orm": "catalog:",
      "rollup": ">=4.59.0",
      "hono": ">=4.12.7",
      "@hono/node-server": ">=1.19.10",
      "minimatch@3": "3.1.4",
      "minimatch@9": "9.0.7",
      "minimatch@10": "10.2.3",
      "ajv@6": "6.14.0",
      "lodash": ">=4.18.0",
      "lodash-es": ">=4.18.0",
      "defu": ">=6.1.5",
      "express-rate-limit": ">=8.2.2",
      "lightningcss": "1.30.1",
      "@react-email/body": "^0.3.0",
      "serialize-javascript": ">=7.0.5",
      "undici": ">=7.24.0",
      "socket.io-parser": ">=4.2.6",
      "flatted": ">=3.4.2",
      "kysely": ">=0.28.14",
      "effect": ">=3.20.0",
      "h3": ">=1.15.9",
      "node-forge": ">=1.4.0",
      "picomatch": ">=4.0.4",
      "yaml@2": ">=2.8.3",
      "path-to-regexp@8": ">=8.4.0",
      "srvx": ">=0.11.13",
      "brace-expansion@1": "1.1.13",
      "brace-expansion@2": "2.0.3",
      "@expo/dom-webview": "55.0.5",
      "@expo/log-box": "55.0.8",
      "tar": ">=7.5.7",
      "vite": ">=7.3.2"
    },
    "ignoredBuiltDependencies": [
      "@prisma/engines",
      "prisma"
    ],
    "peerDependencyRules": {
      "ignoreMissing": [
        "prisma",
        "@prisma/client"
      ],
      "allowedVersions": {
        "magicast": ">=0.3.5"
      }
    },
    "configDependencies": {
      "@pnpm/plugin-types-fixer": "0.1.0+sha512-bLww63gRHi7siYTqFJb5qNdcXadU0jv20Et6z5AryMZ7FlLolbEJOrXLpg8+amQZNHHNW1dfFUBGVw/9ezQbFg=="
    },
    "patchedDependencies": {
      "react-native-leaflet-view@1.1.2": "patches/react-native-leaflet-view@1.1.2.patch"
    }
  },
  "devDependencies": {
    "@lingual/i18n-check": "^0.9.3",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^17.3.1",
    "typescript": "catalog:",
    "vitest": "^4.1.2"
  }
}
