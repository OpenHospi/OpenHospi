{
  "name": "@openhospi/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./types": "./src/types.ts",
    "./validators": "./src/validators/index.ts"
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:push:local": "drizzle-kit push --config=drizzle.local.config.ts",
    "db:setup:storage:local": "tsx scripts/setup-storage-policies.ts",
    "db:studio": "drizzle-kit studio",
    "db:studio:local": "drizzle-kit studio --config=drizzle.local.config.ts",
    "db:seed:local": "tsx scripts/seed-local.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openhospi/i18n": "workspace:*",
    "@openhospi/shared": "workspace:*",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "@types/node": "^24.11.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "1.0.0-beta.15-859cf75",
    "drizzle-seed": "1.0.0-beta.15-859cf75",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-security": "^4.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8"
  }
}
