# =============================================================================
# OpenHospi — Environment Variables (Admin App)
# =============================================================================
# Copy this file to .env.local and fill in the values.
#
# The admin app shares the same database and Better Auth secret as the web app.
# For local dev, run `pnpm supabase:start` from the repo root first.
# =============================================================================

# --- Supabase PostgreSQL ---
# Same database as the web app
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Supabase Client (for storage image URLs) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# --- Better Auth ---
# MUST be the same secret as the web app (shared session DB)
BETTER_AUTH_SECRET=<same value as web app>

# --- GitHub OAuth (admin login) ---
GITHUB_CLIENT_ID=<from GitHub Developer Portal>
GITHUB_CLIENT_SECRET=<from GitHub Developer Portal>
# Set to "false" to allow first admin signup, then remove:
# GITHUB_DISABLE_SIGNUP=false

# --- SMTP (ban/removal notification emails) ---
SMTP_HOST=mail.zxcs.nl
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# --- App URL (for "Back to App" link in sidebar) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Disable Next.js telemetry ---
NEXT_TELEMETRY_DISABLED=1
