{
  "name": "@openhospi/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "exports": {
    ".": "./src/index.ts",
    "./enums": "./src/enums/index.ts",
    "./constants": "./src/constants/index.ts",
    "./constants/*": "./src/constants/*.ts",
    "./error-codes": "./src/error-codes.ts",
    "./api-types": "./src/api-types/index.ts",
    "./calendar": "./src/calendar.ts",
    "./pdok": "./src/pdok.ts",
    "./icons": "./src/icons/index.tsx",
    "./assets/*": "./assets/*"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "devDependencies": {
    "@openhospi/eslint-config": "workspace:*",
    "@types/react": "^19.2.14",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "optionalDependencies": {}
}