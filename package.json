{
  "name": "openhospi",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @openhospi/web dev",
    "build": "pnpm --filter @openhospi/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "pnpm --filter @openhospi/database db:generate",
    "db:migrate": "pnpm --filter @openhospi/database db:migrate",
    "db:push": "pnpm --filter @openhospi/database db:push",
    "db:studio": "pnpm --filter @openhospi/database db:studio",
    "clean": "rm -rf **/node_modules **/.next **/.turbo **/dist"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "@swc/core",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "drizzle-orm": "1.0.0-beta.15-859cf75"
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
